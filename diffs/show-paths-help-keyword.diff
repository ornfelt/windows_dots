+function Show-PathEntry {
+    param(
+        [string]$Label,
+        [string]$Path,
+        [string]$Keyword
+    )
+
+    if ($Keyword) {
+        $k = $Keyword.Trim().ToLower()
+
+        $haystack = "$Label $Path".ToLower()
+
+        if (-not $haystack.Contains($k)) {
+            return
+        }
+    }
+
+    Write-Host "${Label}:" -ForegroundColor DarkGray
+    Write-Host $Path -ForegroundColor Green
+    Write-Host ""
+}
